# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# Local Postgres (docker compose up -d db)
POSTGRES_URL="postgres://postgres:postgres@localhost:55432/gamer_health"

# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
AUTH_SECRET="supersecret"

# OAuth providers (optional in local dev; email/password works without them)
# @see https://www.better-auth.com/docs/authentication/discord
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# @see https://www.better-auth.com/docs/authentication/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
