{
  "name": "@gamer-health/core",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@gamer-health/db": "workspace:*",
    "@gamer-health/validators": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@gamer-health/eslint-config": "workspace:*",
    "@gamer-health/prettier-config": "workspace:*",
    "@gamer-health/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.1.10"
  },
  "prettier": "@gamer-health/prettier-config"
}
